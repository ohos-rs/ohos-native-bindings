{
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "target": "aarch64-unknown-linux-ohos",
          "buildScripts": {
            "overrideCommand": [
              "node",
              "tools/rust-analyzer-ohos-check.mjs",
            ],
          },
        },
        "check": {
          "overrideCommand": [
            "node",
            "tools/rust-analyzer-ohos-check.mjs",
          ],
        },
      },
    },
  },
}
