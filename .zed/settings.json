{
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "target": "aarch64-unknown-linux-ohos",
          "extraEnv": {
            "OHOS_NDK_HOME": "${env:OHOS_NDK_HOME}",
            "OHOS_SDK_HOME": "${env:OHOS_SDK_HOME}",
          },
        },
        "check": {
          "extraEnv": {
            "OHOS_NDK_HOME": "${env:OHOS_NDK_HOME}",
            "OHOS_SDK_HOME": "${env:OHOS_SDK_HOME}",
          },
        },
      },
    },
  },
}
